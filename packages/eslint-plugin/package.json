{
  "name": "@felix-neuro/eslint-plugin-routeguard",
  "version": "0.1.1",
  "description": "ESLint plugin for Node.js API security — detects BOLA/IDOR, mass-assignment, SSRF, SQL injection, command injection, path traversal, open redirect, and hardcoded secrets across Express, Fastify, and NestJS.",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "security",
    "owasp",
    "api-security",
    "bola",
    "idor",
    "ssrf",
    "sql-injection",
    "express",
    "fastify",
    "nestjs",
    "taint-analysis",
    "static-analysis"
  ],
  "author": "FelixMatrixar",
  "license": "MIT",
  "homepage": "https://github.com/FelixMatrixar/routeguard#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/FelixMatrixar/routeguard.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/FelixMatrixar/routeguard/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b && node bundle.mjs",
    "test": "jest",
    "lint": "tsc -b",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "dependencies": {},
  "peerDependencies": {
    "eslint": ">=8"
  },
  "devDependencies": {
    "@routeguard/core": "workspace:*",
    "@routeguard/adapter-express": "workspace:*",
    "@routeguard/adapter-fastify": "workspace:*",
    "@routeguard/adapter-nestjs": "workspace:*",
    "@routeguard/orm-prisma": "workspace:*",
    "@routeguard/orm-drizzle": "workspace:*",
    "@routeguard/orm-typeorm": "workspace:*",
    "@typescript-eslint/utils": "^7.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "@types/eslint": "^8.56.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "esbuild": "^0.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
